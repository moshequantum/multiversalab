# ============================================================
# Multiversa Lab — landing/.env.example
# Copy to .env and fill in real values. NEVER commit .env to git.
# .env and .env.* are gitignored (see .gitignore).
# ============================================================

# ─── Public (baked into the client bundle) ──────────────────
# Use the InsForge ANON key here, NOT the admin API key.
# Get via:  npx @insforge/cli secrets get ANON_KEY
# Or from the InsForge dashboard → Project → API keys → Anon key.
PUBLIC_INSFORGE_URL=https://uzyhdq3q.us-east.insforge.app
PUBLIC_INSFORGE_ANON_KEY=eyJ_paste_your_anon_key_here

# ─── Private (server-only, never reaches the client) ────────
# Admin / service-role key — full access. Use only inside +server.ts files.
# Keep gitignored. Rotate if exposed.
INSFORGE_API_KEY=ik_paste_your_admin_key_here
INSFORGE_API_BASE_URL=https://uzyhdq3q.us-east.insforge.app
